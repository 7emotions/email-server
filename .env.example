# ── Common Settings ──
SECRET_KEY=<change-me>
SUBNET=192.168.203.0/24
SUBNET6=
DOMAIN=ugenrobot.com
HOSTNAMES=mail.ugenrobot.com
POSTMASTER=admin
TLS_FLAVOR=cert
AUTH_RATELIMIT_IP=1/minute
AUTH_RATELIMIT_USER=60/hour
DISABLE_STATISTICS=True

# ── Optional Features ──
ADMIN=true
WEBMAIL=roundcube
API=true
WEBDAV=none
ANTIVIRUS=clamav
SCAN_MACROS=false

# ── Mail Settings ──
MESSAGE_SIZE_LIMIT=50000000
MESSAGE_RATELIMIT=200/hour
RELAYNETS=
RELAYHOST=
FETCHMAIL_ENABLED=false
RECIPIENT_DELIMITER=+
DMARC_RUA=admin
DMARC_RUF=admin
FULL_TEXT_SEARCH=en

# ── Web Settings ──
WEBROOT_REDIRECT=/admin
WEB_ADMIN=/admin
WEB_WEBMAIL=/webmail
WEB_API=/api
SITENAME=ugenrobot.com Mail
WEBSITE=https://ugenrobot.com

# ── Advanced ──
COMPOSE_PROJECT_NAME=mailu
LOG_LEVEL=INFO
TZ=Asia/Shanghai
DEFAULT_SPAM_THRESHOLD=80

# ── Database ──
SQLALCHEMY_DATABASE_URI=sqlite:////data/main.db
SQLALCHEMY_DATABASE_URI_ROUNDCUBE=sqlite:////data/roundcube.db

# ── Infrastructure Addresses (Docker service names) ──
ADMIN_ADDRESS=admin
ANTISPAM_ADDRESS=antispam
ANTIVIRUS_ADDRESS=antivirus
FRONT_ADDRESS=front
IMAP_ADDRESS=imap
REDIS_ADDRESS=redis
SMTP_ADDRESS=smtp
WEBMAIL_ADDRESS=webmail

# ── Docker Settings ──
BIND_ADDRESS4=<SERVER_PRIVATE_IP>
BIND_ADDRESS6=
ROOT=/opt/email-server/data
